{
  "enabledManagers": [
    "dockerfile"
  ],
  "packageRules": [
    {
      "matchManagers": [
        "dockerfile"
      ],
      "matchDepNames": [
        "docker.io/chrislusf/seaweedfs"
      ],
      "versioning": "regex:^(?<major>\\d+)\\.(?<minor>\\d+)_(?<compatibility>full)$"
    },
    {
      "matchManagers": [
        "dockerfile"
      ],
      "groupName": "Docker images",
      "matchUpdateTypes": [
        "minor",
        "patch",
        "digest"
      ]
    }
  ]
}
